<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Radio Widget</string>
    <string name="widget_description">Streaming Radio Widget – Sender direkt vom Homescreen abspielen</string>
    <style name="Theme.RadioWidget" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#1A1A1A</item>
        <item name="colorPrimaryDark">#0F0F0F</item>
        <item name="colorAccent">#E8FF5A</item>
    </style>
    <style name="Theme.RadioWidget.Manager" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#1A1A1A</item>
        <item name="colorPrimaryDark">#0F0F0F</item>
        <item name="colorAccent">#E8FF5A</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#0F0F0F</item>
    </style>
    <style name="Theme.RadioWidget.Transparent" parent="Theme.AppCompat.Dialog">
        <item name="colorPrimary">#1A1A1A</item>
        <item name="colorAccent">#E8FF5A</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>